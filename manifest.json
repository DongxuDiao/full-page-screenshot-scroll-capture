{
  "manifest_version": 3,
  "name": "Scroll Screenshot",
  "version": "1.0.0",
  "description": "Capture full-page scrolling screenshots with area and element selection",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
